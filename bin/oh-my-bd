#!/usr/bin/env zsh
# vim: set filetype=zsh:
# ============================================================
# oh-my-bd — CLI entry point
# ============================================================

export OMBD_DIR="${OMBD_DIR:-$HOME/.oh-my-bd}"

omb_color() {
  local color="$1"; shift
  case "$color" in
    red)    echo "\033[0;31m$*\033[0m" ;;
    green)  echo "\033[0;32m$*\033[0m" ;;
    yellow) echo "\033[0;33m$*\033[0m" ;;
    blue)   echo "\033[0;34m$*\033[0m" ;;
    bold)   echo "\033[1m$*\033[0m" ;;
    *)      echo "$*" ;;
  esac
}

omb_log() {
  local level="$1"; shift
  case "$level" in
    error) echo "[oh-my-bd] $(omb_color red ERROR)  $*" >&2 ;;
    warn)  echo "[oh-my-bd] $(omb_color yellow WARN)  $*" >&2 ;;
    *)     echo "[oh-my-bd] $(omb_color green INFO)  $*" ;;
  esac
}

omb_err() {
  echo "[oh-my-bd] $(omb_color red ERROR)  $*" >&2
}

cmd_install() {
  omb_log "Running install.sh..."
  if [[ -x "${OMBD_DIR}/install.sh" ]]; then
    "${OMBD_DIR}/install.sh"
  else
    omb_err "install.sh not found or not executable."
    return 1
  fi
}

cmd_update() {
  if [[ ! -d "$OMBD_DIR/.git" ]]; then
    omb_err "Not a git repo. Run 'oh-my-bd install' first."
    return 1
  fi

  local current remote
  current="$(cd "$OMBD_DIR" && git rev-parse HEAD 2>/dev/null)"

  (cd "$OMBD_DIR" && git fetch origin main --quiet 2>/dev/null) || {
    omb_err "Update failed. Check: cd $OMBD_DIR && git status"
    return 1
  }

  (cd "$OMBD_DIR" && git reset --hard "origin/main" --quiet 2>/dev/null) || {
    omb_err "Update failed. Check: cd $OMBD_DIR && git status"
    return 1
  }

  remote="$(cd "$OMBD_DIR" && git rev-parse HEAD)"
  if [[ "$current" == "$remote" ]]; then
    echo "Already up to date."
  else
    echo "Updated. Run 'exec zsh' to reload."
  fi
}

cmd_add() {
  local name="${1:?Usage: oh-my-bd add <plugin-name>}"
  local path="${OMBD_DIR}/plugins/${name}.zsh"
  if [[ -f "$path" ]]; then
    omb_err "Plugin already exists: $name"
    return 1
  fi
  cat > "$path" << EOF
# ============================================================
# oh-my-bd — ${name}.zsh — $(date '+%Y-%m-%d')
# ============================================================

EOF
  omb_log "Created: plugins/${name}.zsh"
  omb_log "Edit it at: $path"
}

cmd_remove() {
  local name="${1:?Usage: oh-my-bd remove <plugin-name>}"
  local path="${OMBD_DIR}/plugins/${name}.zsh"
  if [[ ! -f "$path" ]]; then
    omb_err "Plugin not found: $name"
    return 1
  fi
  rm "$path"
  omb_log "Removed: $name"
}

cmd_list() {
  echo "$(omb_color bold Plugins)"
  for f in "${OMBD_DIR}"/plugins/*.zsh(N); do
    echo "  - ${f:t:r}"
  done
}

cmd_uninstall() {
  if [[ ! -d "$OMBD_DIR" ]]; then
    omb_err "Not installed."
    return 1
  fi

  echo "$(omb_color yellow WARNING: This will remove oh-my-bd completely.)"
  read "confirm?Remove oh-my-bd? [y/N] "

  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "Cancelled."
    return
  fi

  # Remove from .zshrc
  if grep -q "oh-my-bd" "${HOME}/.zshrc" 2>/dev/null; then
    sed -i '' '/^# ===.*oh-my-bd/,/^fi$/d' "${HOME}/.zshrc"
    sed -i '' '/^export PATH=".*\.local\/bin/d' "${HOME}/.zshrc"
    echo "  [OK] Removed from .zshrc"
  fi

  # Remove symlink
  if [[ -L "${HOME}/.local/bin/oh-my-bd" ]]; then
    rm -f "${HOME}/.local/bin/oh-my-bd"
    echo "  [OK] Removed CLI symlink"
  fi

  # Remove .oh-my-bd
  if [[ -d "$OMBD_DIR" ]]; then
    rm -rf "$OMBD_DIR"
    echo "  [OK] Removed $OMBD_DIR"
  fi

  echo ""
  echo "  Uninstalled. Restart your shell."
  echo ""
}

cmd_version() {
  echo "oh-my-bd v1.0.0"
}

cmd_help() {
  cat << 'EOF'
oh-my-bd — your personal shell toolkit

Commands:
  install     Run installer
  update      Pull latest changes
  add <name>  Create a new plugin
  remove <n>  Remove a plugin
  list        List plugins
  uninstall   Remove oh-my-bd
  version     Show version
  help        Show this help
EOF
}

CMD="${1:-help}"
case "$CMD" in
  install)   shift; cmd_install "$@" ;;
  update)    shift; cmd_update "$@" ;;
  add)       shift; cmd_add "$@" ;;
  remove)    shift; cmd_remove "$@" ;;
  list)      shift; cmd_list "$@" ;;
  uninstall) shift; cmd_uninstall "$@" ;;
  version)   shift; cmd_version "$@" ;;
  help|--help|-h) cmd_help ;;
  *)         omb_err "Unknown command: $CMD"; echo "Run 'oh-my-bd help' for usage."; return 1 ;;
esac
