#!/usr/bin/env zsh
# vim: set filetype=zsh:
# ============================================================
# oh-my-bd â€” CLI entry point
# ============================================================

export OMBD_DIR="${OMBD_DIR:-$HOME/.oh-my-bd}"

RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
BLUE=$'\033[0;34m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
DIM=$'\033[2m'
RESET=$'\033[0m'

omb() { printf '%b\n' "$1"; }

omb_banner() {
  local b="${BLUE}"
  local r="${RESET}"
  local esc=$'\x1b'
  echo ""
  echo "${b}       ______     __  __        __    __     __  __        ______     ___${r}"
  echo "${b}      /\  __ \   /\ \_\ \      /\ \"-./  \   /\ \_\ \      /\  == \   /\  __-. ${r}"
  echo "${b}      \ \ \/\ \  \ \  __ \     \ \ \-./\ \  \ \____ \     \ \  __<   \ \ \/\ \ ${r}"
  echo "${b}       \ \_____\  \ \_\ \_\     \ \_\ \ \_\  \/\_____\     \ \_____\  \ \____- ${r}"
  echo "${b}        \/_____/   \/_/\/_/      \/_/  \/_/   \/_____/      \/_____/   \/____/ ${r}"
  echo ""
}

cmd_install() {
  omb "${GREEN}Running install.sh...${RESET}"
  if [[ -x "${OMBD_DIR}/install.sh" ]]; then
    "${OMBD_DIR}/install.sh"
  else
    omb "${RED}[ERROR]${RESET} install.sh not found or not executable."
    return 1
  fi
}

cmd_update() {
  if [[ ! -d "$OMBD_DIR/.git" ]]; then
    omb "${RED}[ERROR]${RESET} Not a git repo. Run 'oh-my-bd install' first."
    return 1
  fi

  local current remote
  current="$(cd "$OMBD_DIR" && git rev-parse HEAD 2>/dev/null)"

  (cd "$OMBD_DIR" && git fetch origin main --quiet 2>/dev/null) || {
    omb "${RED}[ERROR]${RESET} Update failed. Check: cd $OMBD_DIR && git status"
    return 1
  }

  (cd "$OMBD_DIR" && git reset --hard "origin/main" --quiet 2>/dev/null) || {
    omb "${RED}[ERROR]${RESET} Update failed. Check: cd $OMBD_DIR && git status"
    return 1
  }

  remote="$(cd "$OMBD_DIR" && git rev-parse HEAD)"
  if [[ "$current" == "$remote" ]]; then
    omb "${YELLOW}Already up to date.${RESET}"
  else
    omb "${GREEN}Updated.${RESET} Run ${CYAN}exec zsh${RESET} to reload."
  fi
}

cmd_add() {
  local name="${1:?Usage: oh-my-bd add <plugin-name>}"
  local path="${OMBD_DIR}/plugins/${name}.zsh"
  if [[ -f "$path" ]]; then
    omb "${RED}[ERROR]${RESET} Plugin already exists: $name"
    return 1
  fi
  cat > "$path" << EOF
# ============================================================
# oh-my-bd â€” ${name}.zsh â€” $(date '+%Y-%m-%d')
# ============================================================

EOF
  omb "${GREEN}Created:${RESET} plugins/${name}.zsh"
  omb "${GREEN}Edit:${RESET} $path"
}

cmd_remove() {
  local name="${1:?Usage: oh-my-bd remove <plugin-name>}"
  local path="${OMBD_DIR}/plugins/${name}.zsh"
  if [[ ! -f "$path" ]]; then
    omb "${RED}[ERROR]${RESET} Plugin not found: $name"
    return 1
  fi
  rm "$path"
  omb "${GREEN}Removed:${RESET} $name"
}

