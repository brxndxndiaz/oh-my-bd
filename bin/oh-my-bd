cmd_list() {
  if [[ -n "$1" ]]; then
    case "$1" in
      compose)  show_help_compose ;;
      docker)   show_help_docker ;;
      git)      show_help_git ;;
      notes)    show_help_notes ;;
      qol)      show_help_qol ;;
      system)   show_help_system ;;
      fzf)      show_help_fzf ;;
      *)
        omb "${RED}Unknown plugin:${RESET} $1"
        omb "Run ${CYAN}omb list${RESET} to see all plugins."
        return 1
        ;;
    esac
    return
  fi

  omb_banner
  omb "${BOLD}${GREEN}plugins${RESET}"
  omb ""

  omb "  ${CYAN}compose${RESET}   Docker Compose shortcuts"
  omb "            ${DIM}-> dcup  dcupd  dcdown  dcstop  dcstart  dclogs  dcexec  dcps${RESET}"
  omb ""

  omb "  ${CYAN}docker${RESET}    Docker context & cleanup"
  omb "            ${DIM}-> ctx  ctx ls  ctx use <name>  clean-containers  clean-images  clean-all${RESET}"
  omb ""

  omb "  ${CYAN}fzf${RESET}       Fuzzy finder integration"
  omb "            ${DIM}-> Ctrl+R  Ctrl+F  Alt+C  vf  fcd${RESET}"
  omb ""

  omb "  ${CYAN}git${RESET}       Git shortcuts"
  omb "            ${DIM}-> status  add  commit  switch  create  sync  fetch  push  pull  log${RESET}"
  omb ""

  omb "  ${CYAN}notes${RESET}     Project-local notes"
  omb "            ${DIM}-> note  notes  note wip  note rm  noteopen${RESET}"
  omb "            ${DIM}-> note task/ctx/bug/idea/code${RESET}"
  omb ""

  omb "  ${CYAN}qol${RESET}       Quality of life"
  omb "            ${DIM}-> cdc  kill-port  gopen  tre  tf${RESET}"
  omb ""

  omb "  ${CYAN}system${RESET}    System utilities"
  omb "            ${DIM}-> ll  la  l  psg  myip  copy  paste${RESET}"
  omb ""

  omb "${DIM}â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€${RESET}"
  omb "${DIM}CLI:${RESET}  install  update  add  remove  list  uninstall  version"
  omb ""
  omb "Run ${CYAN}omb list <plugin>${RESET} for detailed help."
  omb ""
}

cmd_uninstall() {
  if [[ ! -d "$OMBD_DIR" ]]; then
    omb "${RED}[ERROR]${RESET} Not installed."
    return 1
  fi

  omb "${YELLOW}WARNING:${RESET} This will remove oh-my-bd completely."
  read "confirm?Remove oh-my-bd? [y/N] "

  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    omb "Cancelled."
    return
  fi

  if grep -q "oh-my-bd" "${HOME}/.zshrc" 2>/dev/null; then
    sed -i '' '/^# ===.*oh-my-bd/,/^fi$/d' "${HOME}/.zshrc"
    sed -i '' '/^export PATH=".*\.local\/bin/d' "${HOME}/.zshrc"
    omb "  ${GREEN}[OK]${RESET} Removed from .zshrc"
  fi

  if [[ -L "${HOME}/.local/bin/oh-my-bd" ]]; then
    rm -f "${HOME}/.local/bin/oh-my-bd"
    omb "  ${GREEN}[OK]${RESET} Removed CLI symlink"
  fi

  if [[ -d "$OMBD_DIR" ]]; then
    rm -rf "$OMBD_DIR"
    omb "  ${GREEN}[OK]${RESET} Removed $OMBD_DIR"
  fi

  omb ""
  omb "  ${GREEN}Uninstalled.${RESET} Restart your shell."
  omb ""
}

cmd_doctor() {
  local ok=0
  local warn=0
  
  omb_banner
  omb "${BOLD}oh-my-bd doctor${RESET}"
  omb ""
  
  omb "${BOLD}Dependencies${RESET}"
  
  command -v zsh >/dev/null 2>&1 && omb "  ${GREEN}[OK]${RESET} zsh" || { omb "  ${RED}[FAIL]${RESET} zsh"; ((ok++)); }
  command -v git >/dev/null 2>&1 && omb "  ${GREEN}[OK]${RESET} git" || { omb "  ${RED}[FAIL]${RESET} git"; ((ok++)); }
  command -v fzf >/dev/null 2>&1 && omb "  ${GREEN}[OK]${RESET} fzf (optional)" || { omb "  ${YELLOW}[WARN]${RESET} fzf (optional - fzf pickers disabled)"; ((warn++)); }
  command -v docker >/dev/null 2>&1 && omb "  ${GREEN}[OK]${RESET} docker (optional)" || omb "  ${YELLOW}[WARN]${RESET} docker (optional)"
  
  omb ""
  omb "${BOLD}Installation${RESET}"
  
  if [[ -d "$OMBD_DIR" ]]; then
    omb "  ${GREEN}[OK]${RESET} OMBD_DIR: $OMBD_DIR"
  else
    omb "  ${RED}[FAIL]${RESET} OMBD_DIR not found: $OMBD_DIR"
    ((ok++))
  fi
  
  if [[ -f "$OMBD_DIR/lib/core.zsh" ]]; then
    omb "  ${GREEN}[OK]${RESET} core.zsh found"
  else
    omb "  ${RED}[FAIL]${RESET} core.zsh not found"
    ((ok++))
  fi
  
  if grep -q "oh-my-bd" "${HOME}/.zshrc" 2>/dev/null; then
    omb "  ${GREEN}[OK]${RESET} .zshrc configured"
  else
    omb "  ${YELLOW}[WARN]${RESET} oh-my-bd not in .zshrc"
    ((warn++))
  fi
  
  omb ""
  omb "${BOLD}Duplicate Commands${RESET}"
  
  local -A counts
  local cmd
  for cmd in discard; do
    local paths
    paths="$(which -a "$cmd" 2>/dev/null | wc -l | tr -d ' ')"
    if [[ "$paths" -gt 1 ]]; then
      omb "  ${YELLOW}[WARN]${RESET} '$cmd' defined in multiple places ($paths)"
      ((warn++))
    else
      omb "  ${GREEN}[OK]${RESET} $cmd"
    fi
  done
  
  omb ""
  omb "${BOLD}Plugins${RESET}"
  
  local -a plugins=(git docker notes qol system compose fzf)
  for plugin in $plugins; do
    if [[ -f "$OMBD_DIR/plugins/${plugin}.zsh" ]]; then
      omb "  ${GREEN}[OK]${RESET} ${plugin}.zsh"
    else
      omb "  ${DIM}[--]${RESET} ${plugin}.zsh (not loaded)"
    fi
  done
  
  omb ""
  if (( ok > 0 )); then
    omb "${RED}Issues: $ok failures${RESET}"
  elif (( warn > 0 )); then
    omb "${YELLOW}Warnings: $warn${RESET}"
  else
    omb "${GREEN}All checks passed${RESET}"
  fi
  omb ""
}

cmd_search() {
  local query="${1:-}"
  if [[ -z "$query" ]]; then
    omb "Usage: omb search <term>"
    return 1
  fi
  
  omb_banner
  omb "${BOLD}Results for:${RESET} $query"
  omb ""
  
  local -A results
  local cmd desc found=0
  
  results[status]="git status -sb"
  results[add]="git add"
  results[commit]="git commit"
  results[switch]="git switch (fzf picker)"
  results[create]="git switch -c"
  results[sync]="git pull --rebase && git push"
  results[fetch]="git fetch --all"
  results[push]="git push"
  results[pull]="git pull --rebase"
  results[log]="git log --oneline --graph"
  results[undo]="git reset --soft HEAD~1"
  results[discard]="git reset --hard"
  results[stash]="git stash"
  results[branches]="List branches (fzf)"
  results[branch]="Branch manager"
  results[branch_ls]="List all branches"
  results[branch_new]="Create new branch"
  results[repo]="Repo utilities"
  results[repo_open]="Open repo in browser"
  results[repo_root]="Jump to git root"
  results[repo_pr]="Open PR page"
  results[work]="Status summary"
  results[recent]="Recent cdc targets"
  results[prune]="Prune gone branches"
  results[publish]="Push + set upstream"
  results[browse]="Open repo pages"
  results[root]="Jump to git root"
  results[changed]="Show changed files"
  results[cdc]="Jump to project (fzf)"
  results[cdc_add]="Add bookmark"
  results[cdc_rm]="Remove bookmark"
  results[note]="Add project note"
  results[notes]="View notes (fzf)"
  results[kill_port]="Kill process on port"
  results[gopen]="Open in browser"
  results[tre]="Tree view"]
  results[ll]="ls -alFh"
  results[la]="ls -A"
  results[l]="ls -CF"
  results[psg]="ps aux | grep"]
  results[myip]="Show IP address"
  results[copy]="Copy to clipboard"
  results[paste]="Paste from clipboard"
  results[dcup]="docker compose up"
  results[dcdown]="docker compose down"
  results[dcstop]="docker compose stop"
  results[dcstart]="docker compose start"
  results[dclogs]="docker compose logs"
  results[dcexec]="docker compose exec"
  results[dps]="docker ps"
  results[dpsa]="docker ps -a"]
  results[clean_containers]="docker container prune"
  results[clean_images]="docker image prune"
  results[context]="Docker context"
  results[lz]="lazydocker"
  
  for cmd desc in ${(kv)results}; do
    if [[ "${cmd}${desc}" =~ $query ]]; then
      omb "  ${CYAN}${cmd}${RESET}  ${desc}"
      found=1
    fi
  done
  
  if (( !found )); then
    omb "${YELLOW}No matches${RESET}"
  fi
  omb ""
}

