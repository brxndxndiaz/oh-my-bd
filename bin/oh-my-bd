  omb ""
  omb "${BOLD}${CYAN}COMPOSE${RESET}"
  omb "  ${DIM}Docker Compose shortcuts${RESET}"
  omb ""
  omb "${BOLD}USAGE${RESET}"
  omb "  ${GREEN}dcup${RESET}      Start services (docker compose up -d)"
  omb "  ${GREEN}dcupd${RESET}     Same as dcup"
  omb "  ${GREEN}dcdown${RESET}    Stop services (docker compose down)"
  omb "  ${GREEN}dcstop${RESET}    Stop services without removing volumes"
  omb "  ${GREEN}dcstart${RESET}   Start existing services"
  omb "  ${GREEN}dclogs${RESET}    View logs (docker compose logs -f)"
  omb "  ${GREEN}dclogsf${RESET}   View logs for a specific service"
  omb "  ${GREEN}dcexec${RESET}    Run command in running container"
  omb "  ${GREEN}dcps${RESET}      Show running containers"
