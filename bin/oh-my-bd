  omb "${DIM}Run '${CYAN}omb list${DIM}' for full help.${RESET}"
  omb ""
}

cmd_version() {
  omb "${GREEN}oh-my-bd v1.0.0${RESET}"
}

cmd_help() {
  local plugin="${1:-}"
  
  if [[ -n "$plugin" ]]; then
    cmd_list "$plugin"
    return
  fi

  omb_banner
  omb "${BOLD}USAGE${RESET}"
  omb "  ${CYAN}omb${RESET} <command> [args]"
  omb ""
  omb "${BOLD}CLI COMMANDS${RESET}"
  omb "  ${GREEN}install${RESET}         Run the installer"
  omb "  ${GREEN}update${RESET}          Pull latest changes from git"
  omb "  ${GREEN}add <name>${RESET}      Create a new plugin"
  omb "  ${GREEN}remove <name>${RESET}   Remove a plugin"
  omb "  ${GREEN}list [plugin]${RESET}   List plugins (or show plugin help)"
  omb "  ${GREEN}uninstall${RESET}       Remove oh-my-bd completely"
  omb "  ${GREEN}doctor${RESET}         Run diagnostics"
  omb "  ${GREEN}search <term>${RESET}   Search commands"
  omb "  ${GREEN}cheatsheet${RESET}       One-page command reference"
  omb "  ${GREEN}version${RESET}         Show version"
  omb ""
  omb "${DIM}EXAMPLES${RESET}"
  omb "  ${CYAN}omb list${RESET}          List all plugins"
  omb "  ${CYAN}omb list git${RESET}      Show git plugin help"
  omb "  ${CYAN}omb update${RESET}        Pull latest changes"
  omb ""
}

CMD="${1:-}"
if [[ -z "$CMD" || "$CMD" == "help" || "$CMD" == "--help" || "$CMD" == "-h" ]]; then
  cmd_help
else
  shift 2>/dev/null
  case "$CMD" in
    install)    cmd_install "$@" ;;
    update)     cmd_update "$@" ;;
    add)        cmd_add "$@" ;;
    remove)     cmd_remove "$@" ;;
    list)       cmd_list "$@" ;;
    uninstall)  cmd_uninstall "$@" ;;
    doctor)    cmd_doctor "$@" ;;
    search)    cmd_search "$@" ;;
    cheatsheet) cmd_cheatsheet "$@" ;;
    version)   cmd_version "$@" ;;
    *)         omb "${RED}[ERROR]${RESET} Unknown command: $CMD"; omb "Run ${CYAN}omb help${RESET} for usage."; return 1 ;;
  esac
fi
